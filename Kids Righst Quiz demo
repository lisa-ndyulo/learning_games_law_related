<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Know Your Rights! - Kids Quiz</title>
  <style>
    /* Mobile-first, kid-friendly styling with small animations */
    :root{
      --card-bg: #fff;
      --accent: #ffb347;
      --accent-dark: #ff9800;
      --success: #4caf50;
      --shadow: 0 8px 20px rgba(0,0,0,0.15);
      --radius: 16px;
    }
    *{box-sizing:border-box}
    html,body{height:100%;}
    body {
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial;
      background: linear-gradient(135deg,#ffecd2,#fcb69f);
      margin: 0;
      padding: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }

    #quiz-container {
      width: 100%;
      max-width: 520px;
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--shadow);
      text-align: center;
      transform-origin: center;
      animation: popIn 420ms cubic-bezier(.2,.8,.2,1);
    }

    @keyframes popIn{from{transform:scale(.96);opacity:0}to{transform:none;opacity:1}}

    header{display:flex;align-items:center;gap:12px;justify-content:center;margin-bottom:10px}
    header h1{font-size:18px;margin:0}

    #progress-bar{width:100%;height:14px;background:#eee;border-radius:999px;overflow:hidden;margin:10px 0}
    #progress-fill{height:100%;width:0%;background:var(--success);transition:width 360ms cubic-bezier(.2,.9,.3,1)}

    #question-text{font-size:16px;margin:12px 0 6px;color:#333;min-height:48px}

    .choices{display:grid;grid-template-columns:1fr;gap:8px;margin-top:6px}
    .choice-btn{
      background:var(--accent);border:none;padding:12px;border-radius:12px;color:#fff;font-weight:600;font-size:15px;cursor:pointer;outline:none;transition:transform 160ms ease, box-shadow 160ms ease;
    }
    .choice-btn:active{transform:translateY(2px)}
    .choice-btn:hover{background:var(--accent-dark)}

    .small{font-size:13px;color:#666;margin-top:8px}

    .hidden{display:none}

    /* Result */
    .result{padding:8px}
    .big-score{font-size:22px;font-weight:700;margin:8px 0}

    /* make buttons larger on mobile */
    @media(min-width:520px){
      .choices{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>

<div id="quiz-container" role="main" aria-labelledby="title">
  <header>
    <h1 id="title">Know Your Rights! 🎉</h1>
  </header>

  <div id="progress-bar" aria-hidden="true"><div id="progress-fill"></div></div>
  <p id="question-text">Welcome! Ready to begin? (Grade 1–5 friendly)</p>
  <div id="choices" class="choices"></div>

  <div id="controls">
    <button id="start-btn" class="choice-btn">Start Quiz</button>
  </div>

  <p class="small" id="sound-note">Tip: If you don't hear sounds, your browser or sandbox may block audio. The quiz still works!</p>
</div>

<script>
const startBtn = document.getElementById('start-btn');
const questionText = document.getElementById('question-text');
const choicesDiv = document.getElementById('choices');
const progressFill = document.getElementById('progress-fill');
const title = document.getElementById('title');
const soundNote = document.getElementById('sound-note');

const SOUND_URLS = {
  correct: 'https://cdn.pixabay.com/audio/2022/03/15/audio_5e1d922b61.mp3',
  wrong:   'https://cdn.pixabay.com/audio/2022/03/15/audio_b91ee3d34d.mp3',
  click:   'https://cdn.pixabay.com/audio/2022/03/15/audio_0c9e8f3c82.mp3'
};

let audioObjects = { correct: null, wrong: null, click: null };
let audioSupported = true;

function createAudioIfSupported(key){
  if (!audioSupported) return null;
  try{
    if (typeof Audio !== 'function' && typeof Audio !== 'object') return null;
    if (!audioObjects[key]) audioObjects[key] = new Audio(SOUND_URLS[key]);
    return audioObjects[key];
  }catch(err){
    console.warn('Audio creation blocked:', err);
    audioSupported = false;
    return null;
  }
}

async function safePlay(key){
  try{
    const audio = createAudioIfSupported(key);
    if (!audio) return false;
    const playResult = audio.play();
    if (playResult && typeof playResult.then === 'function'){
      await playResult.catch(e => { throw e; });
    }
    return true;
  }catch(err){
    console.warn('Sound play failed for', key, err);
    audioSupported = false;
    return false;
  }
}

function shuffle(arr){ return arr.sort(()=> Math.random() - 0.5); }

let questions = shuffle([
  { q: 'Which right protects you from being hurt or harmed?', choices: ['Right to Safety','Right to Play','Right to Ice Cream'], answer: 0 },
  { q: 'Which right says you must be treated fairly?', choices: ['Right to Fairness','Right to Draw','Right to Jump'], answer: 0 },
  { q: 'Which right lets you say what you think?', choices: ['Right to Freedom of Expression','Right to Sleep','Right to Candy'], answer: 0 },
  { q: 'Which right says everyone should have school?', choices: ['Right to Education','Right to Dance','Right to Toys'], answer: 0 },
  { q: 'Which right protects your privacy?', choices: ['Right to Privacy','Right to Music','Right to Run Fast'], answer: 0 }
]);

let current = 0, score = 0;

startBtn.addEventListener('click', async () => {
  await safePlay('click');
  startBtn.classList.add('hidden');
  loadQuestion();
});

function updateProgress(){
  const pct = Math.round((current / questions.length) * 100);
  progressFill.style.width = pct + '%';
}

function loadQuestion(){
  updateProgress();
  const item = questions[current];
  if (!item) return endQuiz();

  title.textContent = `Question ${current + 1}`;
  questionText.textContent = item.q;

  choicesDiv.innerHTML = '';
  item.choices.forEach((choiceText, idx) => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.type = 'button';
    btn.textContent = choiceText;
    btn.onclick = () => onSelect(idx, btn);
    btn.addEventListener('pointerdown', ()=> btn.style.transform='translateY(2px)');
    btn.addEventListener('pointerup', ()=> btn.style.transform='');
    choicesDiv.appendChild(btn);
  });
}

async function onSelect(selectedIndex, btn){
  Array.from(choicesDiv.querySelectorAll('button')).forEach(b=> b.disabled = true);
  const correctIndex = questions[current].answer;
  if (selectedIndex === correctIndex){
    score++;
    btn.style.boxShadow = '0 6px 18px rgba(76,175,80,0.2)';
    await safePlay('correct');
  }else{
    btn.style.opacity = '0.7';
    await safePlay('wrong');
  }

  setTimeout(()=>{
    current++;
    if (current < questions.length) loadQuestion();
    else endQuiz();
  }, 550);
}

function endQuiz(){
  progressFill.style.width = '100%';
  title.textContent = 'Great Job! 🎉';
  questionText.textContent = `You scored ${score} out of ${questions.length}!`;
  choicesDiv.innerHTML = '';

  const resultBox = document.createElement('div');
  resultBox.className = 'result';
  resultBox.innerHTML = `<div class="big-score">${score} / ${questions.length}</div>`;

  const restart = document.createElement('button');
  restart.className = 'choice-btn';
  restart.textContent = 'Play Again';
  restart.onclick = () => {
    current = 0;
    score = 0;
    questions = shuffle(questions);
    loadQuestion();
  };

  choicesDiv.appendChild(resultBox);
  choicesDiv.appendChild(restart);
}

updateProgress();

try{
  const test = createAudioIfSupported('click');
  if (!test) soundNote.textContent = 'Sound not available in this environment. The quiz still works!';
} catch(e){
  soundNote.textContent = 'Sound not available in this environment. The quiz still works!';
}

</script>

</body>
</html>
