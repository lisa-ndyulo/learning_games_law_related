<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Build a Government</title>
  <style>
    :root {
      --bg: #f3f8ff;
      --card: #ffffff;
      --primary: #0b5ed7;
      --primary-dark: #0849a8;
      --success: #1a7f37;
      --warning: #b54708;
      --text: #12263a;
      --muted: #52667a;
      --radius: 14px;
      --shadow: 0 10px 24px rgba(18, 38, 58, 0.13);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
      background: radial-gradient(circle at 20% 0, #e9f3ff 0, var(--bg) 40%, #eaf7ef 100%);
      color: var(--text);
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 18px;
    }

    .game {
      width: min(820px, 100%);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 22px;
    }

    h1 { margin: 0 0 10px; font-size: 1.5rem; }
    h2 { margin: 0 0 8px; font-size: 1.2rem; }
    p { margin: 0; color: var(--muted); }

    .panel { margin-top: 18px; padding: 16px; border: 1px solid #e5edf6; border-radius: 12px; }
    .label { display: block; font-weight: 600; margin-bottom: 8px; color: var(--text); }
    select, input {
      width: 100%;
      border: 1px solid #c8d7e8;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 0.95rem;
      margin-bottom: 10px;
    }

    .btn {
      border: 0;
      border-radius: 10px;
      background: var(--primary);
      color: white;
      font-weight: 600;
      padding: 10px 14px;
      cursor: pointer;
      margin-right: 6px;
      margin-top: 6px;
    }
    .btn:hover { background: var(--primary-dark); }

    .option-list { display: grid; grid-template-columns: 1fr; gap: 8px; margin: 10px 0; }
    .option-item {
      display: flex;
      gap: 10px;
      align-items: center;
      padding: 9px 10px;
      border: 1px solid #dbe8f5;
      border-radius: 10px;
      background: #f9fcff;
    }

    .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
    .chip {
      background: #eef5ff;
      color: #0d3b85;
      border: 1px solid #d4e4fb;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 0.82rem;
    }

    .feedback {
      margin-top: 14px;
      border-radius: 10px;
      padding: 10px 12px;
      font-weight: 600;
      display: none;
    }
    .feedback.ok { display: block; background: #ebf9ee; color: var(--success); border: 1px solid #c9eccf; }
    .feedback.warn { display: block; background: #fff5ea; color: var(--warning); border: 1px solid #f4d3a7; }

    .summary {
      margin-top: 16px;
      background: #f8fbff;
      border: 1px solid #deebf9;
      border-radius: 10px;
      padding: 10px 12px;
      display: none;
    }

    .stage { display: none; }
    .stage.active { display: block; }

    @media (max-width: 560px) {
      .game { padding: 16px; }
    }
  </style>
</head>
<body>
  <main class="game">
    <h1>Build a Government 🇿🇦</h1>
    <p>First, show that you understand the Constitution. Then you can build South Africa's government structures.</p>

    <section id="stage1" class="panel stage active">
      <h2>What is a constitution?</h2>
      <p>Select <strong>all</strong> correct answers.</p>
      <div class="option-list" id="constitutionOptions"></div>
      <button class="btn" id="checkConstitution">Check Answers</button>
      <button class="btn" id="restartConstitution" style="display:none;">Restart</button>
      <button class="btn" id="continueToMeaning" style="display:none;">Continue</button>
      <div id="constitutionFeedback" class="feedback"></div>
    </section>

    <section id="stage2" class="panel stage">
      <h2>What does it do?</h2>
      <p>Type your answer in your own words.</p>
      <input id="meaningInput" type="text" placeholder="Example: It limits power and protects rights." />
      <button class="btn" id="checkMeaning">Check Answer</button>
      <button class="btn" id="continueToGame" style="display:none;">Continue to structures of government</button>
      <div id="meaningFeedback" class="feedback"></div>
    </section>

    <section id="stage3" class="panel stage">
      <h2>Structures of Government</h2>
      <label class="label" for="branch">1) Select a branch of government</label>
      <select id="branch">
        <option value="">Choose one...</option>
        <option value="Executive">Executive</option>
        <option value="Legislature">Legislature</option>
        <option value="Judiciary">Judiciary</option>
      </select>

      <label class="label" for="functionInput">2) Add one or more functions</label>
      <input id="functionInput" type="text" placeholder="Example: Implements laws and policy" />
      <button class="btn" id="addFunction">Add function</button>
      <div class="chips" id="functionList"></div>

      <label class="label" for="memberInput" style="margin-top: 12px;">3) Add one or more members</label>
      <input id="memberInput" type="text" placeholder="Example: President and Cabinet" />
      <button class="btn" id="addMember">Add member</button>
      <div class="chips" id="memberList"></div>

      <label class="label" for="accountability" style="margin-top: 12px;">4) Which branch does it hold accountable?</label>
      <select id="accountability">
        <option value="">Select branch...</option>
        <option value="Executive">Executive</option>
        <option value="Legislature">Legislature</option>
        <option value="Judiciary">Judiciary</option>
      </select>

      <button class="btn" id="submitGame">Check My Answer</button>
      <div id="gameFeedback" class="feedback"></div>
      <div id="summary" class="summary"></div>
    </section>
  </main>

  <script>
    const constitutionChoices = [
      'Supreme law',
      'Founding document',
      'Rules for only one political party',
      'A temporary campaign promise',
      'A list of school punishments',
      'A social media trend'
    ];
    const constitutionCorrect = new Set(['Supreme law', 'Founding document']);

    const expectedChecks = {
      Executive: 'Legislature',
      Legislature: 'Executive',
      Judiciary: 'Executive'
    };

    const stage1 = document.getElementById('stage1');
    const stage2 = document.getElementById('stage2');
    const stage3 = document.getElementById('stage3');

    const constitutionOptions = document.getElementById('constitutionOptions');
    const constitutionFeedback = document.getElementById('constitutionFeedback');
    const restartConstitution = document.getElementById('restartConstitution');
    const continueToMeaning = document.getElementById('continueToMeaning');

    const meaningInput = document.getElementById('meaningInput');
    const meaningFeedback = document.getElementById('meaningFeedback');
    const continueToGame = document.getElementById('continueToGame');

    const branchEl = document.getElementById('branch');
    const functionInput = document.getElementById('functionInput');
    const memberInput = document.getElementById('memberInput');
    const accountabilityEl = document.getElementById('accountability');
    const functionList = document.getElementById('functionList');
    const memberList = document.getElementById('memberList');
    const gameFeedback = document.getElementById('gameFeedback');
    const summaryEl = document.getElementById('summary');

    const functions = [];
    const members = [];

    function showStage(stage) {
      stage1.classList.remove('active');
      stage2.classList.remove('active');
      stage3.classList.remove('active');
      stage.classList.add('active');
    }

    function renderConstitutionChoices() {
      constitutionOptions.innerHTML = '';
      constitutionChoices.forEach((choice, index) => {
        const row = document.createElement('label');
        row.className = 'option-item';

        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.value = choice;
        checkbox.id = `constitution-${index}`;

        const text = document.createElement('span');
        text.textContent = choice;

        row.appendChild(checkbox);
        row.appendChild(text);
        constitutionOptions.appendChild(row);
      });
    }

    function getSelectedConstitutionOptions() {
      return Array.from(constitutionOptions.querySelectorAll('input:checked')).map(input => input.value);
    }

    function isConstitutionCorrect(selected) {
      if (selected.length !== constitutionCorrect.size) return false;
      return selected.every(option => constitutionCorrect.has(option));
    }

    function normalize(text) {
      return text.toLowerCase().replace(/[^a-z0-9\s]/g, ' ').replace(/\s+/g, ' ').trim();
    }

    function isMeaningCorrect(answer) {
      const text = normalize(answer);
      const checks = [
        /limit(s|ing)? power/.test(text),
        /establish(es|ing)? (the )?(government|state)/.test(text),
        /define(s|d)? (the )?(powers|functions?) (of )?(government)/.test(text),
        /protect(s|ing)? rights?/.test(text),
        /(supreme law.*south africa|south africa.*supreme law)/.test(text)
      ];
      return checks.some(Boolean);
    }

    function renderChips(target, items) {
      target.innerHTML = '';
      items.forEach(item => {
        const chip = document.createElement('span');
        chip.className = 'chip';
        chip.textContent = item;
        target.appendChild(chip);
      });
    }

    function addItem(input, collection, view) {
      const value = input.value.trim();
      if (!value) return;
      collection.push(value);
      input.value = '';
      renderChips(view, collection);
    }

    renderConstitutionChoices();

    document.getElementById('checkConstitution').addEventListener('click', () => {
      const selected = getSelectedConstitutionOptions();

      if (isConstitutionCorrect(selected)) {
        constitutionFeedback.className = 'feedback ok';
        constitutionFeedback.textContent = 'Excellent! You got both correct. You are ready to continue.';
        continueToMeaning.style.display = 'inline-block';
        restartConstitution.style.display = 'none';
      } else {
        constitutionFeedback.className = 'feedback warn';
        constitutionFeedback.textContent = 'You cannot create a government yet. Restart and try again.';
        restartConstitution.style.display = 'inline-block';
        continueToMeaning.style.display = 'none';
      }
    });

    restartConstitution.addEventListener('click', () => {
      constitutionOptions.querySelectorAll('input').forEach(input => {
        input.checked = false;
      });
      constitutionFeedback.className = 'feedback';
      constitutionFeedback.textContent = '';
      restartConstitution.style.display = 'none';
      continueToMeaning.style.display = 'none';
    });

    continueToMeaning.addEventListener('click', () => showStage(stage2));

    document.getElementById('checkMeaning').addEventListener('click', () => {
      const answer = meaningInput.value.trim();
      if (!answer) {
        meaningFeedback.className = 'feedback warn';
        meaningFeedback.textContent = 'Please type an answer first.';
        continueToGame.style.display = 'none';
        return;
      }

      if (isMeaningCorrect(answer)) {
        meaningFeedback.className = 'feedback ok';
        meaningFeedback.textContent = 'Great explanation! Continue to the structures of government page.';
        continueToGame.style.display = 'inline-block';
      } else {
        meaningFeedback.className = 'feedback warn';
        meaningFeedback.textContent = 'Almost there. Include ideas like limiting power, establishing government, defining powers/functions, protecting rights, or being South Africa\'s supreme law.';
        continueToGame.style.display = 'none';
      }
    });

    continueToGame.addEventListener('click', () => showStage(stage3));

    document.getElementById('addFunction').addEventListener('click', () => addItem(functionInput, functions, functionList));
    document.getElementById('addMember').addEventListener('click', () => addItem(memberInput, members, memberList));

    document.getElementById('submitGame').addEventListener('click', () => {
      const branch = branchEl.value;
      const accountable = accountabilityEl.value;

      if (!branch || functions.length === 0 || members.length === 0 || !accountable) {
        gameFeedback.className = 'feedback warn';
        gameFeedback.textContent = 'Please complete all steps: choose a branch, add at least one function, add at least one member, and choose accountability.';
        summaryEl.style.display = 'none';
        return;
      }

      const expected = expectedChecks[branch];
      const accurate = accountable === expected;

      gameFeedback.className = accurate ? 'feedback ok' : 'feedback warn';
      gameFeedback.textContent = accurate
        ? 'Great work! Your accountability link is correct.'
        : `Nice try! For ${branch}, a better answer is ${expected}.`;

      summaryEl.style.display = 'block';
      summaryEl.innerHTML = `
        <strong>Your Government Card:</strong><br>
        Branch: ${branch}<br>
        Functions: ${functions.join('; ')}<br>
        Members: ${members.join('; ')}<br>
        Holds accountable: ${accountable}
      `;
    });
  </script>
</body>
</html>
